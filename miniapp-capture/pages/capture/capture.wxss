.page {
  position: relative;
  width: 100vw;
  height: 100vh;
  background: #111;
  overflow: hidden;
}

.camera,
.camera-placeholder {
  width: 100%;
  height: 100%;
}

.camera-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.3);
}

.preview-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.85;
}


.overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx 32rpx 60rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.75));
}

.status-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.status-dot.idle     { background: rgba(255,255,255,0.3); }
.status-dot.uploading{ background: #C8A84B; animation: pulse 1s ease-in-out infinite; }
.status-dot.ok       { background: #4CAF7D; animation: pulse 2s ease-in-out infinite; }
.status-dot.error    { background: #E85A5A; }

.status-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.meta-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.meta-item {
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
}

.battery-warn {
  font-size: 24rpx;
  color: #E8943A;
  margin-bottom: 20rpx;
  background: rgba(232,148,58,0.12);
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
}

.btn-row {
  display: flex;
  justify-content: center;
}

.btn {
  padding: 22rpx 80rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.btn-start {
  background: #4CAF7D;
  color: #fff;
}

.btn-stop {
  background: rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.8);
  border: 1rpx solid rgba(255,255,255,0.2);
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.4; }
}
