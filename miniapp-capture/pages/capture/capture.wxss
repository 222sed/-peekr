.page {
  position: relative;
  width: 100vw;
  height: 100vh;
  background: #111;
  overflow: hidden;
}

.camera,
.camera-placeholder {
  width: 100%;
  height: 100%;
}

.camera-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.3);
}

.preview-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.88;
}

.feeding-zone-live {
  position: absolute;
  z-index: 4;
  box-sizing: border-box;
  border: 4rpx solid rgba(245, 158, 11, 0.68);
  border-radius: 16rpx;
  background: rgba(245, 158, 11, 0.12);
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.12);
  pointer-events: none;
}

.feeding-zone-live.feeding-idle {
  border-color: rgba(180, 180, 180, 0.6);
  background: rgba(180, 180, 180, 0.1);
}

.feeding-zone-live.feeding-outside,
.feeding-zone-live.feeding-waiting {
  border-color: rgba(245, 158, 11, 0.68);
  background: rgba(245, 158, 11, 0.12);
}

.feeding-zone-live.feeding-candidate {
  border-color: rgba(232, 148, 58, 0.95);
  background: rgba(232, 148, 58, 0.22);
  box-shadow: 0 0 24rpx rgba(232, 148, 58, 0.3);
}

.feeding-zone-live.feeding-confirmed {
  border-color: rgba(76, 175, 125, 0.95);
  background: rgba(76, 175, 125, 0.22);
  box-shadow: 0 0 24rpx rgba(76, 175, 125, 0.34);
}

.feeding-zone-live.feeding-missing {
  border-color: rgba(232, 90, 90, 0.72);
  background: rgba(232, 90, 90, 0.12);
}

.feeding-zone-live-label {
  position: absolute;
  left: 12rpx;
  top: 10rpx;
  padding: 7rpx 14rpx;
  border-radius: 18rpx;
  color: rgba(255, 247, 230, 0.92);
  background: rgba(180, 104, 5, 0.7);
  font-size: 20rpx;
  line-height: 1.2;
}

.settings-button {
  position: absolute;
  z-index: 35;
  top: calc(env(safe-area-inset-top) + 24rpx);
  left: 26rpx;
  width: 82rpx;
  height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 255, 255, 0.52);
  border-radius: 50%;
  color: #fff;
  background: radial-gradient(circle at 35% 25%, rgba(255, 255, 255, 0.26), rgba(20, 20, 20, 0.58));
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.24);
  backdrop-filter: blur(14rpx);
}

.settings-icon {
  font-size: 36rpx;
  line-height: 1;
}

.settings-backdrop {
  position: absolute;
  z-index: 25;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(0, 0, 0, 0.25);
}

.settings-menu {
  position: absolute;
  z-index: 34;
  top: calc(env(safe-area-inset-top) + 120rpx);
  left: 26rpx;
  width: 620rpx;
  max-width: calc(100vw - 52rpx);
  overflow: hidden;
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  border-radius: 34rpx;
  color: #fff;
  background: linear-gradient(180deg, rgba(36, 38, 38, 0.96), rgba(21, 22, 22, 0.96));
  box-shadow: 0 24rpx 70rpx rgba(0, 0, 0, 0.44);
  backdrop-filter: blur(18rpx);
}

.settings-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 26rpx 26rpx 20rpx;
}

.settings-title {
  color: rgba(255, 255, 255, 0.96);
  font-size: 30rpx;
  font-weight: 800;
}

.settings-subtitle {
  margin-top: 7rpx;
  color: rgba(255, 255, 255, 0.48);
  font-size: 21rpx;
}

.settings-close {
  width: 54rpx;
  height: 54rpx;
  flex-shrink: 0;
  border-radius: 50%;
  color: rgba(255, 255, 255, 0.74);
  background: rgba(255, 255, 255, 0.10);
  font-size: 36rpx;
  line-height: 50rpx;
  text-align: center;
}

.settings-item {
  min-height: 108rpx;
  margin: 0 16rpx 14rpx;
  padding: 18rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.06);
}

.settings-item-main {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.settings-item-icon {
  width: 54rpx;
  height: 54rpx;
  flex-shrink: 0;
  border-radius: 50%;
  text-align: center;
  color: #2d2112;
  background: #f5bd66;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 54rpx;
}

.settings-item-label {
  color: rgba(255, 255, 255, 0.94);
  font-size: 26rpx;
  font-weight: 700;
}

.settings-item-desc {
  margin-top: 7rpx;
  overflow: hidden;
  color: rgba(255, 255, 255, 0.46);
  font-size: 21rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.settings-arrow {
  color: rgba(255, 255, 255, 0.36);
  font-size: 40rpx;
}

.settings-item.danger .settings-item-icon,
.settings-item.danger .settings-item-label {
  color: #ee8c8c;
}

.settings-item.danger .settings-item-icon {
  color: #fff;
  background: rgba(238, 140, 140, 0.22);
}

.settings-switch {
  position: relative;
  width: 78rpx;
  height: 44rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.16);
}

.settings-switch.on {
  background: #e8943a;
}

.settings-switch-dot {
  position: absolute;
  top: 5rpx;
  left: 6rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #fff;
}

.settings-switch.on .settings-switch-dot {
  transform: translateX(32rpx);
}

.overlay {
  position: absolute;
  z-index: 5;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx 32rpx 48rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.82));
}

.status-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.status-dot.idle { background: rgba(255, 255, 255, 0.3); }
.status-dot.uploading { background: #c8a84b; animation: pulse 1s ease-in-out infinite; }
.status-dot.ok { background: #4caf7d; animation: pulse 2s ease-in-out infinite; }
.status-dot.error { background: #e85a5a; }

.status-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 24rpx;
  margin-bottom: 20rpx;
}

.meta-item {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.48);
}

.zone-ready { color: #f7bd58; }
.zone-missing { color: #e8a1a1; }

.feeding-feedback {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 16rpx;
  color: rgba(255, 255, 255, 0.86);
  background: rgba(255, 255, 255, 0.1);
  font-size: 23rpx;
}

.feeding-feedback-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.42);
  flex-shrink: 0;
}

.feeding-feedback.feeding-missing {
  background: rgba(232, 90, 90, 0.16);
  color: #ffd1d1;
}

.feeding-feedback.feeding-missing .feeding-feedback-dot {
  background: #e85a5a;
}

.feeding-feedback.feeding-idle {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.62);
}

.feeding-feedback.feeding-outside,
.feeding-feedback.feeding-waiting {
  background: rgba(245, 158, 11, 0.14);
  color: #ffe0a8;
}

.feeding-feedback.feeding-outside .feeding-feedback-dot,
.feeding-feedback.feeding-waiting .feeding-feedback-dot {
  background: #f59e0b;
}

.feeding-feedback.feeding-candidate {
  background: rgba(232, 148, 58, 0.24);
  color: #ffd28a;
}

.feeding-feedback.feeding-candidate .feeding-feedback-dot {
  background: #e8943a;
  animation: pulse 1s ease-in-out infinite;
}

.feeding-feedback.feeding-confirmed {
  background: rgba(76, 175, 125, 0.22);
  color: #caffdf;
}

.feeding-feedback.feeding-confirmed .feeding-feedback-dot {
  background: #4caf7d;
}

.upload-panel {
  margin-bottom: 18rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 20rpx;
  background: rgba(18, 18, 18, 0.62);
  backdrop-filter: blur(12rpx);
}

.upload-panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.upload-state {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.upload-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.upload-dot.idle { background: rgba(255, 255, 255, 0.32); }
.upload-dot.uploading { background: #f5bd58; animation: pulse 1s ease-in-out infinite; }
.upload-dot.ok { background: #4caf7d; }
.upload-dot.error { background: #e85a5a; }

.upload-title {
  color: #fff;
  font-size: 25rpx;
  font-weight: 700;
}

.upload-busy {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(245, 189, 88, 0.18);
  color: #ffd58b;
  font-size: 19rpx;
}

.upload-test {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #d9f1ff;
  background: rgba(74, 144, 217, 0.24);
  font-size: 21rpx;
}

.upload-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-top: 16rpx;
}

.upload-cell {
  min-width: 0;
}

.upload-label {
  display: block;
  color: rgba(255, 255, 255, 0.42);
  font-size: 18rpx;
}

.upload-value {
  display: block;
  margin-top: 5rpx;
  overflow: hidden;
  color: rgba(255, 255, 255, 0.88);
  font-size: 20rpx;
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.upload-error {
  margin-top: 14rpx;
  padding: 10rpx 12rpx;
  border-radius: 12rpx;
  color: #ffd4d4;
  background: rgba(232, 90, 90, 0.17);
  font-size: 21rpx;
}

.upload-server {
  margin-top: 12rpx;
  overflow: hidden;
  color: rgba(255, 255, 255, 0.34);
  font-size: 18rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.battery-warn {
  font-size: 24rpx;
  color: #e8943a;
  margin-bottom: 20rpx;
  background: rgba(232, 148, 58, 0.12);
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
}

.quality-warn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
  padding: 14rpx 18rpx;
  border: 1rpx solid rgba(245, 185, 87, 0.26);
  border-radius: 14rpx;
  color: #ffd28a;
  background: rgba(133, 79, 10, 0.46);
  font-size: 23rpx;
}

.quality-warn-icon {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
  border-radius: 50%;
  color: #503000;
  background: #f5b957;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 30rpx;
  text-align: center;
}

.reconnect-hint {
  margin-bottom: 18rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 23rpx;
}

.btn-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
}

.btn {
  padding: 20rpx 34rpx;
  border-radius: 48rpx;
  font-size: 27rpx;
  font-weight: 600;
  text-align: center;
}

.btn {
  min-width: 210rpx;
}

.btn-start {
  background: #4caf7d;
  color: #fff;
}

.btn-stop {
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.setup-mask {
  position: absolute;
  z-index: 30;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 46rpx;
  background: rgba(0, 0, 0, 0.72);
}

.setup-card {
  width: 100%;
  padding: 48rpx 38rpx 36rpx;
  border-radius: 30rpx;
  background: #f8f5ef;
  box-sizing: border-box;
  text-align: center;
}

.setup-icon { font-size: 74rpx; }

.setup-title {
  margin-top: 18rpx;
  color: #2f302d;
  font-size: 36rpx;
  font-weight: 700;
}

.setup-desc {
  margin-top: 22rpx;
  color: #64645f;
  font-size: 27rpx;
  line-height: 1.7;
}

.setup-note {
  margin-top: 24rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  color: #9a6b23;
  background: #fff2d9;
  font-size: 23rpx;
  line-height: 1.55;
}

.setup-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 34rpx;
}

.setup-skip,
.setup-primary {
  flex: 1;
  padding: 22rpx 0;
  border-radius: 44rpx;
  font-size: 27rpx;
  font-weight: 600;
}

.setup-skip {
  color: #777;
  background: #ebe7df;
}

.setup-primary {
  color: #fff;
  background: #e8943a;
}

.calibration-camera {
  position: absolute;
  z-index: 20;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: #fff;
  pointer-events: none;
}

.food-calibration-camera {
  position: absolute;
  z-index: 22;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: #fff;
  pointer-events: none;
}

.food-zone-guide {
  position: absolute;
  z-index: 2;
  box-sizing: border-box;
  border: 5rpx dashed #f59e0b;
  border-radius: 16rpx;
  background: rgba(245, 158, 11, 0.12);
  color: #fff0cf;
  font-size: 22rpx;
  pointer-events: none;
}

.food-zone-guide text {
  display: inline-block;
  margin: 10rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  background: rgba(149, 85, 0, 0.78);
}

.calibration-top {
  padding: 52rpx 36rpx 80rpx;
  text-align: center;
  background: linear-gradient(rgba(0, 0, 0, 0.72), transparent);
}

.calibration-title {
  font-size: 34rpx;
  font-weight: 700;
}

.calibration-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.72);
}

.camera-guide {
  position: absolute;
  left: 12%;
  right: 12%;
  top: 34%;
  height: 30%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
}

.guide-corner {
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  border-color: #f5b957;
}

.guide-tl { left: 0; top: 0; border-left: 5rpx solid; border-top: 5rpx solid; }
.guide-tr { right: 0; top: 0; border-right: 5rpx solid; border-top: 5rpx solid; }
.guide-bl { left: 0; bottom: 0; border-left: 5rpx solid; border-bottom: 5rpx solid; }
.guide-br { right: 0; bottom: 0; border-right: 5rpx solid; border-bottom: 5rpx solid; }

.calibration-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 50rpx 52rpx 70rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.86));
  pointer-events: auto;
}

.calibration-cancel,
.calibration-placeholder {
  width: 140rpx;
  color: #fff;
  font-size: 26rpx;
}

.calibration-placeholder {
  text-align: right;
  color: rgba(255, 255, 255, 0.45);
}

.shutter {
  width: 116rpx;
  height: 116rpx;
  border: 6rpx solid #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.shutter-inner {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #fff;
}

.shutter-inner.busy {
  opacity: 0.45;
}

.calibration-editor {
  position: absolute;
  z-index: 40;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #1b1b1b;
  color: #fff;
}

.editor-header {
  flex-shrink: 0;
  padding: calc(env(safe-area-inset-top) + 20rpx) 34rpx 18rpx;
  text-align: center;
}

.editor-title {
  font-size: 31rpx;
  font-weight: 700;
}

.editor-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

.calibration-stage {
  position: relative;
  flex-shrink: 0;
  align-self: center;
  max-width: 100%;
  max-height: 100%;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 18rpx;
  background: #101010;
  box-shadow: 0 10rpx 32rpx rgba(0, 0, 0, 0.24);
  line-height: 0;
}

.calibration-photo {
  display: block;
  width: 100%;
  height: 100%;
}

.feeding-zone-editor {
  position: absolute;
  box-sizing: border-box;
  border: 5rpx dashed #f59e0b;
  background: rgba(245, 158, 11, 0.19);
  line-height: normal;
  touch-action: none;
}

.feeding-zone-label {
  position: absolute;
  left: 0;
  top: -48rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx 12rpx 12rpx 0;
  color: #1f1605;
  background: #f59e0b;
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
}

.resize-handle {
  position: absolute;
  right: -24rpx;
  bottom: -24rpx;
  width: 52rpx;
  height: 52rpx;
  border: 5rpx solid #fff;
  border-radius: 50%;
  background: #f59e0b;
}

.editor-tip {
  flex-shrink: 0;
  margin: 16rpx 28rpx 0;
  padding: 13rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(245, 158, 11, 0.13);
  color: #f4c572;
  font-size: 21rpx;
  line-height: 1.4;
}

.editor-actions {
  flex-shrink: 0;
  display: flex;
  gap: 14rpx;
  margin-top: auto;
  padding: 18rpx 28rpx calc(env(safe-area-inset-bottom) + 22rpx);
  background: #1b1b1b;
}

.editor-action {
  flex: 1;
  padding: 18rpx 8rpx;
  border-radius: 38rpx;
  text-align: center;
  font-size: 23rpx;
  font-weight: 600;
}

.editor-action.secondary {
  color: #ddd;
  background: #303030;
}

.editor-action.primary {
  color: #fff;
  background: #e8943a;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}
