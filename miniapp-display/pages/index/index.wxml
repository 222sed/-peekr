<view class="page">

  <view class="header">
    <view>
      <view class="pill" style="border-color: {{stateColor}}">
        <view class="pill-dot" style="background: {{stateColor}}"></view>
        <text class="pill-text">{{stateLabel}}</text>
      </view>
      <text class="device-info" wx:if="{{deviceInfo}}">{{deviceInfo}}</text>
    </view>
    <text class="last-updated" wx:if="{{lastUpdated}}">{{lastUpdated}} 更新</text>
  </view>

  <view class="body-row">
    <view class="cat-col">
      <view class="cat-wrap state-{{state}}">
        <image wx:if="{{state === 'sleep'}}" class="cat-img cat-sleep" src="/assets/cat-sleep.svg" mode="aspectFit"/>
        <image wx:elif="{{state === 'play'}}" class="cat-img cat-play" src="/assets/cat-play.svg" mode="aspectFit"/>
        <image wx:elif="{{state === 'food'}}" class="cat-img cat-food" src="/assets/cat-food.svg" mode="aspectFit"/>
        <image wx:else class="cat-img cat-dream" src="/assets/cat-dream.svg" mode="aspectFit"/>
      </view>
      <text class="cat-name">小灰</text>
      <view class="cat-status">
        <view class="status-dot-sm" style="background:{{stateColor}}"></view>
        <text class="cat-status-text">{{stateLabel}}</text>
      </view>
      <text class="cat-desc">{{stateDesc}}</text>
    </view>

    <view class="metrics-col">
      <view class="metric-row" wx:for="{{metrics}}" wx:key="key">
        <view class="metric-label-row">
          <text class="metric-icon">{{item.icon}} {{item.label}}</text>
          <text class="metric-val">{{item.value}}{{item.unit}}</text>
        </view>
        <view class="metric-bar">
          <view class="metric-fill {{item.colorClass}}" style="width:{{item.barValue}}%"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="timeline-wrap">
    <view class="tl-header">
      <text class="tl-title">今日时间轴</text>
      <text class="tl-range">00:00 — 现在</text>
    </view>
    <view class="tl-track">
      <view
        wx:for="{{timeline}}"
        wx:key="index"
        class="tl-seg tl-{{item.type}}"
        style="width:{{item.pct}}%"
      ></view>
    </view>
  </view>

  <view class="offline-banner" wx:if="{{!connected}}">
    采集端未连接，请检查采集小程序是否保持监控
  </view>

</view>
